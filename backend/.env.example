PORT=3000

# ── Supabase (produção — configurar no painel Vercel/Railway) ──
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── JWT para autenticação de moderadores ───────────────────────
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ── CORS ───────────────────────────────────────────────────────
# Dev local:
CORS_ORIGIN=http://localhost:5173
# Produção (frontend Vercel):
# CORS_ORIGIN=https://pz-rank.vercel.app

TABLE_NAME=entries

# ── Dev local (SQLite, sem Supabase) ────────────────────────────
# Usar .env.local com USE_SQLITE=true em vez de alterar este arquivo.
# USE_SQLITE=true
# SUPABASE_URL e SUPABASE_SERVICE_KEY não são necessários com USE_SQLITE=true
