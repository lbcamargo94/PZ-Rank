{
  "name": "pz-rank-backend",
  "version": "1.0.0",
  "description": "PZ Community Rank — API backend",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/sqlite-schema.sql','dist/db/sqlite-schema.sql');console.log('postbuild: sqlite-schema.sql copiado')\"",
    "start": "node dist/index.js",
    "start:local": "node --env-file=.env.local dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
